{
  "name": "deep-factor-tui",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "deepfactor": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/postbuild.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "deep-factor-agent": "workspace:*",
    "dotenv": "^16.6.1",
    "ink": "^6.8.0",
    "meow": "^13.2.0",
    "react": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "description": "Inline terminal UI for the [deep-factor-agent](../deep-factor-agent) — an LLM agent loop with tool use, human-in-the-loop, and token tracking. Built with [Ink](https://github.com/vadimdemedes/ink) (React for the terminal) and [meow](https://github.com/sindresorhus/meow) for arg parsing.",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
